# Katafract screenshot pipeline — fastlane lanes
# Doctrine: feedback_screenshots_never_manual.md (capture is on-demand;
# fastlane wraps the capture + frameit + ASC delivery steps but does NOT
# auto-publish — Tek must sign off PNGs before any submit_* lane runs).

default_platform(:ios)

platform :ios do

  # Capture only — output: fastlane/screenshots/<device>/<en-US>/<frame>.png
  desc "Capture 8-frame screenshots locally (iPhone 6.9\" + iPad 13\")"
  lane :screenshots do
    capture_ios_screenshots
    frameit(
      path: "./fastlane/screenshots",
      use_platform: "IOS",
      silver: false,
      rose_gold: false
    )
  end

  desc "Frame already-captured screenshots in fastlane/screenshots/ (no re-capture)"
  lane :frame_only do
    frameit(
      path: "./fastlane/screenshots",
      use_platform: "IOS",
      silver: false,
      rose_gold: false
    )
  end

  desc "Capture + upload App Store screenshots to ASC (no binary, no metadata)"
  lane :submit_version_screenshots do
    capture_ios_screenshots
    frameit(
      path: "./fastlane/screenshots",
      use_platform: "IOS"
    )
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  # Re-upload framed screenshots from existing fastlane/screenshots/ without
  # re-capturing. Use this for the 2.3.3 rejection fix on the rejected v1.2.5
  # — Apple expressly allows resubmitting screenshots on a rejected version
  # without a new build.
  desc "Re-upload framed screenshots to ASC for the rejected v1.2.5 (no binary)"
  lane :submit_screenshots_only do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      app_version: "1.2.5",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      screenshots_path: "./fastlane/screenshots",
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Legacy alias — re-upload version screenshots (kept for compatibility)"
  lane :resubmit_version_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end
end
